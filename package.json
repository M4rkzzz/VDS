{
  "name": "screenshare-relay",
  "version": "1.5.0",
  "description": "Multi-viewer screen sharing with cascade relay (蜈蚣法) - Electron Edition",
  "main": "desktop/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "server": "node server/index.js",
    "build": "electron-builder",
    "rebuild": "electron-rebuild -f",
    "prepare-server-release": "node scripts/prepare-server-release.js",
    "build:release": "npm run build && npm run prepare-server-release"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "koffi": "^2.15.1",
    "process-audio-capture": "^1.0.14",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "electron": "^39.0.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9"
  },
  "build": {
    "appId": "com.vds.app",
    "productName": "VDS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "desktop/**/*",
      "server/public/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "desktop/app.ico",
      "artifactName": "VDS-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "generic",
      "url": "https://boshan.s.3q.hair/updates/",
      "useMultipleRangeRequest": false
    }
  }
}
