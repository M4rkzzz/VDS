{
  "name": "screenshare-relay",
  "version": "1.6.6",
  "description": "Multi-viewer screen sharing with cascade relay (蜈蚣法) - Electron Edition",
  "main": "desktop/main.js",
  "scripts": {
    "start": "powershell -ExecutionPolicy Bypass -File scripts/start-electron-dev.ps1 .",
    "dev": "powershell -ExecutionPolicy Bypass -File scripts/start-electron-dev.ps1 .",
    "dev:dual": "powershell -ExecutionPolicy Bypass -File scripts/start-dual-test-env.ps1",
    "dev:dual:native": "powershell -ExecutionPolicy Bypass -File scripts/start-dual-test-env.ps1 -EnableNativePeerTransport",
    "dual:web": "powershell -ExecutionPolicy Bypass -File scripts/start-dual-web-test-env.ps1 -EnableNativePeerTransport",
    "triple:nwn": "powershell -ExecutionPolicy Bypass -File scripts/start-triple-nwn-test-env.ps1 -EnableNativePeerTransport",
    "dev:dual:web": "powershell -ExecutionPolicy Bypass -File scripts/start-dual-web-test-env.ps1 -EnableNativePeerTransport",
    "dev:triple": "powershell -ExecutionPolicy Bypass -File scripts/start-triple-test-env.ps1",
    "dev:triple:native": "powershell -ExecutionPolicy Bypass -File scripts/start-triple-test-env.ps1 -EnableNativePeerTransport",
    "server": "node server/index.js",
    "build:vds-web": "vite build --config vds_web/vite.config.ts",
    "check:vds-web": "tsc -p vds_web/tsconfig.json --noEmit",
    "test:vds-web": "node scripts/test-vds-web-protocol.js",
    "build": "electron-builder",
    "build:media-agent": "powershell -ExecutionPolicy Bypass -File scripts/build-media-agent.ps1 -Configuration Release",
    "smoke:media-agent": "powershell -ExecutionPolicy Bypass -File scripts/smoke-media-agent.ps1",
    "test:media-agent": "powershell -ExecutionPolicy Bypass -File scripts/test-media-agent.ps1 -Configuration Release",
    "test:server": "node scripts/test-server-core.js",
    "verify:media-agent": "powershell -ExecutionPolicy Bypass -File scripts/verify-media-agent.ps1 -Configuration Release",
    "check:logging": "powershell -ExecutionPolicy Bypass -File scripts/check-logging-policy.ps1",
    "e2e:media-agent": "powershell -ExecutionPolicy Bypass -File scripts/manual-media-agent-e2e.ps1",
    "rebuild": "electron-rebuild -f",
    "prepare-server-release": "node scripts/prepare-server-release.js",
    "release:check": "node scripts/release-check.js",
    "build:release": "npm run build:vds-web && npm run build && npm run prepare-server-release"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "express": "^4.18.2",
    "koffi": "^2.15.1",
    "process-audio-capture": "^1.0.14",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "electron": "^39.0.0",
    "electron-builder": "^25.1.8",
    "electron-rebuild": "^3.2.9",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "build": {
    "appId": "com.vds.app",
    "productName": "VDS",
    "directories": {
      "output": "dist"
    },
    "files": [
      "desktop/**/*",
      "server/public/**/*"
    ],
    "extraResources": [
      {
        "from": "runtime/media-agent",
        "to": "runtime/media-agent",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "desktop/app.ico",
      "artifactName": "VDS-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": {
      "provider": "generic",
      "url": "https://boshan.s.3q.hair/updates/",
      "useMultipleRangeRequest": false
    }
  }
}
